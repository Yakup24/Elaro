{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=Elaro;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost",
      "https://localhost"
    ]
  },
  "Jwt": {
    "Issuer": "Elaro",
    "Audience": "ElaroClients",
    "Key": "development_only_jwt_key_32_chars!!",
    "AccessTokenMinutes": 60
  },
  "Swagger": {
    "EnableInProduction": false
  },
  "RateLimiting": {
    "ApiPermitLimit": 300,
    "AuthPermitLimit": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
